#!/usr/bin/env ruby
# Parse trace files in coverage/traces/ produced by lib/coverage.sh,
# convert them to a SimpleCov resultset, and write coverage/index.html.

require "json"
require "fileutils"
require "simplecov"
require "set"

REPO_ROOT = ENV["BUILDPACK_REPO_ROOT"] || Dir.pwd
TRACES_DIR = File.join(Dir.pwd, "coverage", "traces")
COVERAGE_DIR = File.join(Dir.pwd, "coverage")

# Bash xtrace prefixes statements with one or more '+'. Sourced or subshell
# contexts produce '++COV:' / '+++COV:' / etc., so accept any positive count.
# Format: +COV:file:line:funcname: (funcname may be empty at top-level)
COV_LINE = /\A\++COV:([^:]+):(\d+):([^:]*):/.freeze

# Files matching these globs become part of the coverage report. Each line in
# the source is classified as executable (0, if not yet hit) or non-executable
# (nil, for blanks and pure comments), then bumped to actual hit count if traced.
WATCHED = [
  /\Abin\/[^\/]+\z/,        # bin/compile, bin/detect, bin/release, etc.
  /\Alib\/[^\/]+\.sh\z/,    # lib/*.sh (one level deep — excludes lib/vendor/)
  /\Aprofile\/[^\/]+\z/,    # profile/*
].freeze

def parse_trace(path)
  hits = Hash.new { |h, k| h[k] = Hash.new(0) }
  # Track which functions have been entered to mark their declaration lines.
  func_entries = Hash.new { |h, k| h[k] = Set.new }

  File.foreach(path) do |line|
    next unless m = COV_LINE.match(line)
    rel = m[1]
    line_no = m[2].to_i
    func_name = m[3]
    next unless WATCHED.any? { |rx| rx.match?(rel) }
    hits[rel][line_no] += 1

    # If we see a function name for the first time, we've entered that function.
    # We'll need to find its declaration line in a second pass.
    func_entries[rel] << func_name unless func_name.empty?
  end

  # Second pass: mark function declaration lines as executed if the function ran.
  mark_function_declarations!(hits, func_entries)

  hits
end

# Find function declarations in source files and mark them as executed if the
# function was entered during trace collection. Bash function declarations are
# typically of the form: `function_name() {` or `function function_name() {`
def mark_function_declarations!(hits, func_entries)
  func_entries.each do |rel, func_names|
    abs = File.join(REPO_ROOT, rel)
    next unless File.exist?(abs)

    File.foreach(abs).with_index(1) do |line, line_no|
      func_names.each do |func_name|
        # Match: funcname() { or function funcname() {
        if line =~ /\b#{Regexp.escape(func_name)}\(\)\s*\{/ ||
           line =~ /\bfunction\s+#{Regexp.escape(func_name)}\(\)/
          hits[rel][line_no] += 1
        end
      end
    end
  end
end

def merge!(into, from)
  from.each do |rel, lines|
    target = into[rel] ||= Hash.new(0)
    lines.each { |ln, cnt| target[ln] += cnt }
  end
end

# Read a file, classify each line as executable (0) or non-executable (nil).
# Returns an Array sized to file's line count, or [] if the file is missing.
def initial_coverage_array(abs_path)
  arr = []
  File.foreach(abs_path) do |line|
    stripped = line.strip
    if stripped.empty? || stripped.start_with?("#")
      arr << nil      # blank line or pure comment — not executable
    else
      arr << 0        # executable, not yet hit
    end
  end
  arr
rescue Errno::ENOENT
  []
end

# Convert {rel => {line_no => hit_count}} into SimpleCov's
# {abs_path => {"lines" => [hit_count_or_nil, ...]}} format.
# Lines that exist in the source but never appeared in the trace stay at 0
# (executable, not covered) — making the coverage report actually useful.
def to_simplecov(hits)
  result = {}
  hits.each do |rel, line_hits|
    abs = File.join(REPO_ROOT, rel)
    arr = initial_coverage_array(abs)
    next if arr.empty?
    line_hits.each do |ln, cnt|
      idx = ln - 1
      next unless idx >= 0 && idx < arr.length
      # If the line was classified non-executable but actually ran, the
      # trace is more authoritative — promote to hit count.
      arr[idx] = cnt
    end
    result[abs] = { "lines" => arr }
  end
  result
end

def main
  unless Dir.exist?(TRACES_DIR)
    warn "No traces directory at #{TRACES_DIR}. Run `make coverage` first."
    exit 1
  end

  trace_files = Dir.glob(File.join(TRACES_DIR, "*.log"))
  if trace_files.empty?
    warn "No trace files found in #{TRACES_DIR}."
    exit 1
  end

  combined = {}
  trace_files.each { |path| merge!(combined, parse_trace(path)) }

  if combined.empty?
    warn "Parsed #{trace_files.length} trace file(s) but no +COV: lines matched watched globs."
    exit 1
  end

  simplecov_data = to_simplecov(combined)

  SimpleCov.coverage_dir COVERAGE_DIR
  SimpleCov.root REPO_ROOT
  resultset = { "buildpack" => { "coverage" => simplecov_data, "timestamp" => Time.now.to_i } }
  FileUtils.mkdir_p(COVERAGE_DIR)
  File.write(File.join(COVERAGE_DIR, ".resultset.json"), JSON.pretty_generate(resultset))

  result = SimpleCov::Result.new(simplecov_data)
  result.command_name = "buildpack"
  result.format!

  puts "Coverage report: #{File.join(COVERAGE_DIR, "index.html")}"
  puts "Files measured: #{simplecov_data.length}"
end

main
