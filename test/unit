  # Test with engines.yarn using tilde
  echo '{"engines": {"yarn": "~3.6.0"}}' > "$build_dir/package.json"
  assertEquals "3" "$(get_yarn_major_version "$build_dir")"

  # Cleanup
  rm -rf "$build_dir"
}

